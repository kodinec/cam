# Copy to /home/.env on Ubuntu server and adjust values.

# Camera #1 (Kurokesu C3 4K)
CAM1_DEVICE=/dev/video0
CAM1_RES=1920x1080
CAM1_FPS=25
CAM1_GOP=25
CAM1_THREAD_QUEUE=256

# CAM1 motorized lens map (L085)
# Host file that will be mounted into container as /app/zoom8_focusmap.json
CAM1_MAP_FILE=./zoom8_focusmap.json
CAM1_MAP_PATH=/app/zoom8_focusmap.json
CAM1_MAP_STEPS=8
CAM1_MAP_FEED=180

# Start flow: RESET -> UNLOCK -> LED -> IRIS -> HOME -> BACKOFF -> GOTO START -> G92
CAM1_RESET=true
CAM1_LIMIT_LED=true
CAM1_IRIS_OPEN=true
CAM1_HOME_FOCUS=true
CAM1_HOME_TIMEOUT=25
CAM1_BACKOFF_X=1.0
CAM1_BACKOFF_Y=0.5
CAM1_BACKOFF_FEED=120
CAM1_START_X=0.0
CAM1_START_Y=0.0
CAM1_GOTO_FEED=200
CAM1_AUTO_RELEASE=true
CAM1_RELEASE_STEP_X=0.2
CAM1_RELEASE_STEP_Y=0.2
CAM1_RELEASE_MAX_STEPS=40
CAM1_RELEASE_FEED=80

# Camera #2 (NVECTECH PATRIOT 2 H50)
# Prefer stable by-id path instead of /dev/videoN indexes:
#   ls -l /dev/v4l/by-id/
# Example:
#   CAM2_DEVICE=/dev/v4l/by-id/usb-rockchip_UVC-video-index0
CAM2_DEVICE=/dev/video2
CAM2_CONTROL_DEVICE=/dev/video2
# Use mjpeg for compatibility; if H50 h264 input is stable in your setup, set CAM2_INPUT_FORMAT=h264 for lower latency.
CAM2_INPUT_FORMAT=mjpeg
CAM2_RES=1024x768
CAM2_FPS=25
CAM2_GOP=25
CAM2_THREAD_QUEUE=256
CAM2_ANALYZE_DURATION=5M
CAM2_PROBE_SIZE=5M

# MediaMTX bases used by ptz-service reverse proxy
CAM1_HLS_BASE=http://mediamtx:8888/cam1/
CAM2_HLS_BASE=http://mediamtx:8888/cam2/
CAM1_RTC_BASE=http://mediamtx:8889/
CAM2_RTC_BASE=http://mediamtx:8889/
WEBRTC_ADDITIONAL_HOSTS=10.10.45.39

# PTZ service
PTZ_SERIAL=/dev/ttyACM0
PTZ_BAUD=115200
PTZ_USER=admin
PTZ_PASS=admin
