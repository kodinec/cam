PTZ_SERIAL=/dev/ttyACM0
PTZ_SERIAL_FALLBACK=/dev/serial/by-id/usb-tomeko_net_STM32F103C8T6_6D8648755083-if00
PTZ_BAUD=115200
PTZ_RESET=true
PTZ_LIMIT_LED=true
PTZ_IRIS_OPEN=true
PTZ_HOME_TIMEOUT=25
PTZ_BACKOFF_X=1.0
PTZ_BACKOFF_Y=0.5
PTZ_BACKOFF_FEED=120
PTZ_GOTO_FEED=200
PTZ_START_X=0.0
PTZ_START_Y=0.0
PTZ_RELEASE_STEP_X=0.2
PTZ_RELEASE_STEP_Y=0.2
PTZ_RELEASE_MAX_STEPS=40
PTZ_RELEASE_FEED=80
PTZ_INIT_MAX_TRIES=0
PTZ_INIT_RETRY_SEC=2

