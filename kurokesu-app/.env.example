# Host ports
WEB_PORT=8787
MTX_RTSP_PORT=8554
MTX_WEBRTC_ICE_PORT=8189
# Must match the LAN/WAN address that the browser uses to open http://<host>:8787.
# Replace with the first non-docker address from `hostname -I` on the target host.
WEBRTC_ADDITIONAL_HOSTS=10.10.45.39

# Camera stream
CAM1_DEVICE=/dev/v4l/by-id/usb-Kurokesu_C3_4K_00001-video-index0
CAM1_MODE=mjpeg
CAM1_FPS=25
CAM1_RES=1920x1080
CAM1_THREAD_QUEUE=64
CAM1_ENCODER=h264_vaapi
CAM1_VAAPI_FALLBACK=true
CAM1_VAAPI_DRIVER=iHD
CAM1_VAAPI_RC_MODE=quality
CAM1_RTBUF_SIZE=64M
CAM1_X264_PRESET=superfast
CAM1_X264_TUNE=zerolatency
CAM1_X264_PROFILE=high
CAM1_CRF=13
# Used by libx264 and by h264_vaapi only when CAM1_VAAPI_RC_MODE=bitrate.
CAM1_BITRATE=20M
CAM1_BUFSIZE=40M
CAM1_X264_PARAMS=bframes=0:rc-lookahead=0:sync-lookahead=0:scenecut=0
CAM1_VAAPI_DEVICE=/dev/dri/renderD128
# Used by h264_vaapi only when CAM1_VAAPI_RC_MODE=quality.
CAM1_VAAPI_QP=18
CAM1_GOP=15
CAM1_RTSP_URL=rtsp://mediamtx:8554/cam1

# Web app
LISTEN=:8787
CAMERA_NAME=Kurokesu C3 4K + L085/L085D
# Keep the reverse proxy target on the internal Docker network.
RTC_BASE=http://mediamtx:8889/
CAM_MAP_PATH=/app/focusmap.json
CAM_MAP_STEPS=8
CAM_STRICT_MAP_LIMITS=true
CAM_MAP_FEED=180
CAM_FOCUS_FINE_STEP=0.05
APP_USER=
APP_PASS=

# PTZ controller
# Prefer a stable /dev/serial/by-id/... path when available.
PTZ_SERIAL=/dev/ttyACM0
PTZ_SERIAL_FALLBACK=/dev/serial/by-id/
PTZ_BAUD=115200
CAM_RESET=true
CAM_LIMIT_LED=true
CAM_IRIS_OPEN=true
CAM_HOME_FOCUS=true
CAM_HOME_TIMEOUT=25
CAM_BACKOFF_X=1.0
CAM_BACKOFF_Y=0.5
CAM_BACKOFF_FEED=120
CAM_START_X=0.0
CAM_START_Y=0.0
CAM_GOTO_FEED=200
CAM_AUTO_RELEASE=true
CAM_RELEASE_STEP_X=0.2
CAM_RELEASE_STEP_Y=0.2
CAM_RELEASE_MAX_STEPS=40
CAM_RELEASE_FEED=80
