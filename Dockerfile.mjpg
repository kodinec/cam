# syntax=docker/dockerfile:1.7

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates mjpg-streamer v4l-utils \
    && rm -rf /var/lib/apt/lists/*

COPY scripts/mjpg-entrypoint.sh /usr/local/bin/mjpg-entrypoint
RUN chmod +x /usr/local/bin/mjpg-entrypoint

ENTRYPOINT ["/usr/local/bin/mjpg-entrypoint"]
